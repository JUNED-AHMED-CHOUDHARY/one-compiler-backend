model Companies {
  id         String   @id @default(cuid())
  name       String   @unique
  slug_name  String   @unique
  image      String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  problem_links ProblemCompanies[]
}

model TopicTags {
  id          String   @id @default(cuid())
  name        String   @unique
  slug_name   String   @unique
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  problem_links ProblemTags[]
}

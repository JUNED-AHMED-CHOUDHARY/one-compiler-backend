generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  PROBLEM_SETTER
  PROBLEM_SOLVER
}

model User {
  id String @id // primary key
  email String @unique
  password_hash String
  role UserRole
  username String @unique
  name String
  user_image String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  meta_data Json @default("{}")
}